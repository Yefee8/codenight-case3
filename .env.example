# Copy to .env, then replace every CHANGE_ME value with a unique secret.
# Safe generator: openssl rand -hex 32

COMPOSE_PROJECT_NAME=fraudcell
FRONTEND_PORT=3000
GATEWAY_PORT=8080
LOG_LEVEL=INFO

# Frontend server session/BFF settings. Set COOKIE_SECURE=true behind HTTPS.
AUTH_SECRET=CHANGE_ME_frontend_auth_64_hex_characters
COOKIE_SECURE=false

# Shared JWT contract. JWKS remains on the private identity-service network.
JWT_ISSUER=https://identity.fraudcell.local
JWT_AUDIENCE=fraudcell-api
JWT_KEY_ID=fraudcell-local-2026

# Local demo seed/login. Set DEMO_MODE=false and COOKIE_SECURE=true outside local HTTP.
DEMO_MODE=true
DEMO_OTP_CODE=1234

# Identity PostgreSQL
IDENTITY_DB_NAME=fraudcell_identity
IDENTITY_DB_BOOTSTRAP_PASSWORD=CHANGE_ME_identity_db_bootstrap
IDENTITY_DB_MIGRATION_USER=identity_migrator
IDENTITY_DB_MIGRATION_PASSWORD=CHANGE_ME_identity_db_migration
IDENTITY_DB_RUNTIME_USER=identity_app
IDENTITY_DB_RUNTIME_PASSWORD=CHANGE_ME_identity_db_runtime

# Transaction PostgreSQL
TRANSACTION_DB_NAME=fraudcell_transaction
TRANSACTION_DB_BOOTSTRAP_PASSWORD=CHANGE_ME_transaction_db_bootstrap
TRANSACTION_DB_MIGRATION_USER=transaction_migrator
TRANSACTION_DB_MIGRATION_PASSWORD=CHANGE_ME_transaction_db_migration
TRANSACTION_DB_RUNTIME_USER=transaction_app
TRANSACTION_DB_RUNTIME_PASSWORD=CHANGE_ME_transaction_db_runtime

# AI PostgreSQL
AI_DB_NAME=fraudcell_ai
AI_DB_BOOTSTRAP_PASSWORD=CHANGE_ME_ai_db_bootstrap
AI_DB_MIGRATION_USER=ai_migrator
AI_DB_MIGRATION_PASSWORD=CHANGE_ME_ai_db_migration
AI_DB_RUNTIME_USER=ai_app
AI_DB_RUNTIME_PASSWORD=CHANGE_ME_ai_db_runtime

# Gamification PostgreSQL
GAMIFICATION_DB_NAME=fraudcell_gamification
GAMIFICATION_DB_BOOTSTRAP_PASSWORD=CHANGE_ME_gamification_db_bootstrap
GAMIFICATION_DB_MIGRATION_USER=gamification_migrator
GAMIFICATION_DB_MIGRATION_PASSWORD=CHANGE_ME_gamification_db_migration
GAMIFICATION_DB_RUNTIME_USER=gamification_app
GAMIFICATION_DB_RUNTIME_PASSWORD=CHANGE_ME_gamification_db_runtime

# Physically separate Redis instances
GATEWAY_REDIS_PASSWORD=CHANGE_ME_gateway_redis
GAMIFICATION_REDIS_PASSWORD=CHANGE_ME_gamification_redis

# One-time RabbitMQ bootstrap, persistent operator, and one account per service
RABBITMQ_BOOTSTRAP_USER=fraudcell_bootstrap
RABBITMQ_BOOTSTRAP_PASSWORD=CHANGE_ME_rabbitmq_bootstrap
RABBITMQ_OPERATOR_USER=fraudcell_operator
RABBITMQ_OPERATOR_PASSWORD=CHANGE_ME_rabbitmq_operator
IDENTITY_RABBITMQ_USER=identity_service
IDENTITY_RABBITMQ_PASSWORD=CHANGE_ME_identity_rabbitmq
TRANSACTION_RABBITMQ_USER=transaction_service
TRANSACTION_RABBITMQ_PASSWORD=CHANGE_ME_transaction_rabbitmq
AI_RABBITMQ_USER=ai_service
AI_RABBITMQ_PASSWORD=CHANGE_ME_ai_rabbitmq
GAMIFICATION_RABBITMQ_USER=gamification_service
GAMIFICATION_RABBITMQ_PASSWORD=CHANGE_ME_gamification_rabbitmq
GATEWAY_RABBITMQ_USER=gateway_service
GATEWAY_RABBITMQ_PASSWORD=CHANGE_ME_gateway_rabbitmq

# Internal service authentication and Gateway HMAC key (minimum 32 characters)
AI_INTERNAL_TOKEN=CHANGE_ME_ai_internal_token_64_hex_characters
GATEWAY_KEY_HMAC_SECRET=CHANGE_ME_gateway_hmac_64_hex_characters

# Used only with docker-compose.observability.yml
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin
